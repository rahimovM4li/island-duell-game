{
  "name": "island-duell",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "assets:build": "node scripts/optimize-game-assets.mjs",
    "assets:validate": "node scripts/optimize-game-assets.mjs --validate-only",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "node --import tsx server/src/index.ts",
    "typecheck": "tsc -p shared/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "npm run build && playwright test"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.1",
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.1.2",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "overrides": {
    "sharp": "^0.35.3"
  }
}
